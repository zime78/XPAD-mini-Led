{
  "schema_version": 1,
  "diagram_type": "workflow",
  "meta": {
    "title": "P2~P5 앱 키매핑 동작",
    "subtitle": "설정 → RAM 적용 → 물리 키 실행 → 종료 원복",
    "output": "key-mapping.html",
    "viewBox": [720, 760]
  },
  "lanes": [
    { "id": "ui", "label": "사용자 · 설정 UI" },
    { "id": "main", "label": "Electron Main · KeyActionRouter" },
    { "id": "worker", "label": "Device Worker · 안전 적용" },
    { "id": "device", "label": "XPAD Mini · macOS 입력" }
  ],
  "nodes": [
    {
      "id": "choose",
      "lane": "ui",
      "col": 0,
      "type": "frontend",
      "label": "앱 선택",
      "sublabel": "P2~P5 하단 3키",
      "width": 92
    },
    {
      "id": "save",
      "lane": "ui",
      "col": 1,
      "type": "frontend",
      "label": "저장 · 적용",
      "sublabel": ".app 절대경로",
      "width": 84
    },
    {
      "id": "press",
      "lane": "ui",
      "col": 4,
      "type": "external",
      "label": "물리 키 누름",
      "sublabel": "선택 프로필",
      "width": 82
    },
    {
      "id": "quit",
      "lane": "ui",
      "col": 5,
      "type": "external",
      "label": "앱 종료",
      "sublabel": "정상 shutdown",
      "width": 74
    },
    {
      "id": "validate",
      "lane": "main",
      "col": 0,
