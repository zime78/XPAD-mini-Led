      "toSide": "top",
      "route": "drop"
    },
    { "from": "validate", "to": "shortcut", "variant": "emphasis" },
    {
      "from": "shortcut",
      "to": "backup",
      "label": "등록 성공 후",
      "variant": "emphasis",
      "fromSide": "bottom",
      "toSide": "top",
      "route": "drop"
    },
    {
      "from": "backup",
      "to": "profile",
      "label": "첫 쓰기 전",
      "variant": "security",
      "fromSide": "bottom",
      "toSide": "top",
      "route": "drop",
      "bias": 0.65
    },
    { "from": "profile", "to": "keyinfo", "variant": "security" },
    {
      "from": "keyinfo",
      "to": "apply",
      "label": "검증 완료",
      "variant": "emphasis",
      "fromSide": "top",
      "toSide": "bottom",
      "route": "drop"
    },
    {
      "from": "apply",
      "to": "press",
      "label": "사용 준비",
      "variant": "emphasis",
      "fromSide": "top",
      "toSide": "bottom",
      "route": "up-channel",
      "channelY": 34,
      "labelSegment": 1
    },
    {
      "from": "press",
      "to": "emit",
      "variant": "emphasis",
      "fromSide": "bottom",
      "toSide": "top",
      "route": "drop"
    },
    {
      "from": "emit",
      "to": "route",
      "label": "F16~F18",
      "variant": "emphasis",
      "fromSide": "top",
      "toSide": "bottom",
      "route": "drop"
    },
    { "from": "route", "to": "launch", "variant": "emphasis" },
    {
      "from": "quit",
      "to": "restore",
      "variant": "security",
      "fromSide": "right",
      "toSide": "right",
      "route": "outside-right",
      "labelSegment": 1
    },
    {
      "from": "restore",
      "to": "original",
      "label": "56B 원본",
      "variant": "security",
      "fromSide": "bottom",
      "toSide": "top",
      "route": "drop"
    }
  ],
  "cards": [
    {
      "dot": "cyan",
      "title": "버튼 대응",
      "items": [
        "왼쪽 = F16 · 가운데 = F17 · 오른쪽 = F18",
        "선택된 P2~P5 프로필의 로컬 동작으로 라우팅",
        "P1은 이전 곡 · 재생/일시정지 · 다음 곡으로 고정"
      ]
    },
    {
      "dot": "rose",
      "title": "실패 안전",
      "items": [
        "첫 쓰기 전에 12개 KeyInfo 원본을 모두 백업",
        "쓰기마다 56바이트 전체 readback 검증",
        "부분 실패 · 비활성화 · 정상 종료 시 원복"
      ]
    },
    {
      "dot": "emerald",
      "title": "영구 변경 없음",
      "items": [
        "장치 RAM만 변경하고 Save(0x0D)는 호출하지 않음",
        "Profile 1 하단 키와 노브 클릭은 변경하지 않음",
        "LED · 펌웨어 · 부트로더 명령 미사용"
      ]
    }
  ]
}
